# ===========================================
# Wilbor Assist v2 - Variáveis de Ambiente
# ===========================================

# ===========================================
# DATABASE (Obrigatório)
# ===========================================
DATABASE_URL=mysql://user:password@host:port/database

# ===========================================
# STRIPE (Obrigatório para pagamentos)
# ===========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===========================================
# WHATSAPP BUSINESS API (Opcional)
# ===========================================
WHATSAPP_ACCESS_TOKEN=xxx
WHATSAPP_PHONE_NUMBER_ID=xxx
WHATSAPP_VERIFY_TOKEN=wilbor_webhook_token

# ===========================================
# OPENAI (Obrigatório para IA)
# ===========================================
OPENAI_API_KEY=sk-xxx

# ===========================================
# GOOGLE OAUTH (Opcional)
# ===========================================
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx

# ===========================================
# AWS S3 (Opcional - para uploads)
# ===========================================
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
AWS_REGION=us-east-1
AWS_BUCKET_NAME=wilbor-assets

# ===========================================
# SESSION & SECURITY
# ===========================================
SESSION_SECRET=your-session-secret-here

# ===========================================
# NOTIFICATIONS (Opcional)
# ===========================================
NOTIFICATION_EMAIL=notifications@wilbor.com

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=development